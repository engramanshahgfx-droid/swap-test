              "raw": "{{base_url}}/api/swap-requests",
              "host": ["{{base_url}}"],
              "path": ["api", "swap-requests"]
            }
          }
        },
        {
          "name": "Approve Swap Request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{base_url}}/api/swap-requests/1/approve",
              "host": ["{{base_url}}"],
              "path": ["api", "swap-requests", "1", "approve"]
            }
          }
        },
        {
          "name": "Reject Swap Request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Not available on that date\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/swap-requests/1/reject",
              "host": ["{{base_url}}"],
              "path": ["api", "swap-requests", "1", "reject"]
            }
          }
        }
      ]
    },
    {
      "name": "Messages & Notifications",
      "item": [
        {
          "name": "Get Messages",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/messages?conversation_id=1",
              "host": ["{{base_url}}"],
              "path": ["api", "messages"],
              "query": [
                {
                  "key": "conversation_id",
                  "value": "1"
                }
              ]
            }
          }
        },
