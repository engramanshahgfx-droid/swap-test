      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "auth_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "user_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "test_otp",
      "value": "",
      "type": "string"
    },
    {
      "key": "requires_verification",
      "value": "",
