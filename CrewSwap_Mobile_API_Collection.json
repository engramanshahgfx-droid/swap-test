{
  "info": {
    "name": "CrewSwap Mobile API",
    "description": "Complete mobile authentication and main endpoints for CrewSwap app",
    "version": "1.0"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "1. Register New User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('user_id', jsonData.data.user.id);",
                  "    pm.environment.set('auth_token', jsonData.data.token);",
                  "    pm.environment.set('test_otp', jsonData.data.test_otp);",
                  "    pm.environment.set('requires_verification', jsonData.data.requires_verification);",
                  "",
                  "    console.log('✅ Registration successful!');",
                  "    console.log('User ID: ' + jsonData.data.user.id);",
                  "    console.log('Test OTP: ' + jsonData.data.test_otp);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employee_id\": \"EMP001\",\n  \"full_name\": \"Test User\",\n  \"phone\": \"+1234567890\",\n  \"email\": \"testuser@example.com\",\n  \"country_base\": \"US\",\n  \"airline_id\": 1,\n  \"plane_type_id\": 1,\n  \"position_id\": 1,\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/register",
              "host": ["{{base_url}}"],
              "path": ["api", "register"]
            }
          }
        },
        {
          "name": "2. Verify OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('auth_token', jsonData.data.token);",
                  "    console.log('✅ OTP verified successfully!');",
                  "    console.log('New Token: ' + jsonData.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": {{user_id}},\n  \"otp\": \"{{test_otp}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/verify-otp",
              "host": ["{{base_url}}"],
              "path": ["api", "verify-otp"]
            }
          }
        },
        {
          "name": "3. Login (After Phone Verification)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('auth_token', jsonData.data.token);",
                  "    console.log('✅ Login successful!');",
                  "    console.log('Token: ' + jsonData.data.token);",
                  "} else if (pm.response.code === 403) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('test_otp', jsonData.data.test_otp);",
                  "    console.log('⚠️ Phone not verified. Use OTP: ' + jsonData.data.test_otp);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/login",
              "host": ["{{base_url}}"],
              "path": ["api", "login"]
            }
          }
        },
        {
          "name": "4. Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{base_url}}/api/refresh-token",
              "host": ["{{base_url}}"],
              "path": ["api", "refresh-token"]
            }
          }
        },
        {
          "name": "5. Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{base_url}}/api/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "Trips & Swaps",
      "item": [
        {
          "name": "Get User Trips",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/user-trips",
              "host": ["{{base_url}}"],
              "path": ["api", "user-trips"]
            }
          }
        },
        {
          "name": "Get Available Trips for Swap",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
              }
            ],
